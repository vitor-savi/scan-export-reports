# ============================================================
# Oracle
# ============================================================
ORACLE_CLIENT_PATH=C:\oracle\instantclient_23_9
ORACLE_DSN=server:port/database

# Opcional: se vazio, o script pedirá as credenciais no terminal
ORACLE_USER=
ORACLE_PASSWORD=

# ============================================================
# MSSQL
# ============================================================
MSSQL_SERVER=server_name
MSSQL_DATABASE=database_name
MSSQL_TABLE=table_name
MSSQL_TRUSTED_CONNECTION=yes

# ============================================================
# Arquivos de saída
# ============================================================
ORACLE_OUTPUT_FILE=relatorio.xlsx
ORACLE_LOG_FILE=console.log
ORACLE_CHECKPOINT_FILE=checkpoint.txt

MSSQL_OUTPUT_FILE=output_file.csv

# ============================================================
# Performance
# ============================================================
ORACLE_FETCH_SIZE=5000
ORACLE_MAX_RETRIES=5
ORACLE_RETRY_WAIT=30

MSSQL_CHUNK_SIZE=100000
